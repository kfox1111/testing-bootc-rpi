#!/bin/bash
# ha-node-setup: one-time per-node configuration for the HA NAT router.
#
# The bootc image is identical on both nodes; everything node-specific lives
# in /etc (machine-local, survives bootc upgrades) and is generated here:
#   /etc/ha-router/node.env                        - per-node identity
#   /etc/keepalived/keepalived.conf                - rendered from template
#   /etc/conntrackd/conntrackd.conf                - rendered from template
#   /etc/NetworkManager/system-connections/*.nmconnection - heartbeat + LAN
#   /root/.ssh/id_ed25519(.pub), authorized_keys   - lease-sync rsync trust
#
# Typical bring-up:
#   node1# ha-node-setup --node 1
#   node2# ha-node-setup --node 2 --authorize-key 'ssh-ed25519 AAAA... root@node1'
#   node1# ha-node-setup --node 1 --authorize-key 'ssh-ed25519 AAAA... root@node2'
# (re-running is idempotent; each run prints this node's public key)

set -euo pipefail

usage() {
    cat <<'EOF'
Usage: ha-node-setup --node <1|2> [options]

Options:
  --node <1|2>             Which node this machine is (required).
  --wan-mac <mac>          Shared WAN MAC address, identical on both nodes
                           (default: 02:11:22:33:44:55, locally administered).
  --hb-ip <ip>             This node's heartbeat IP   (default 10.0.0.1 / 10.0.0.2).
  --peer-hb-ip <ip>        Peer's heartbeat IP        (default the other one).
  --lan-ip <ip>            This node's LAN IP         (default 192.168.1.2 / .3).
  --peer-lan-ip <ip>       Peer's LAN IP              (default the other one).
  --lan-vip <ip/prefix>    Shared LAN virtual IP      (default 192.168.1.1/24).
  --authorize-key '<pub>'  Append the peer's ssh public key to
                           /root/.ssh/authorized_keys (repeatable).
  --no-restart             Write configs but do not reload/restart services.
  -h, --help               Show this help.
EOF
}

NODE=""
WAN_MAC="02:11:22:33:44:55"
HB_IP=""
PEER_HB_IP=""
LAN_IP=""
PEER_LAN_IP=""
LAN_VIP="192.168.1.1/24"
RESTART=1
AUTH_KEYS=()

while [ $# -gt 0 ]; do
    case "$1" in
        --node)          NODE="$2"; shift 2 ;;
        --wan-mac)       WAN_MAC="$2"; shift 2 ;;
        --hb-ip)         HB_IP="$2"; shift 2 ;;
        --peer-hb-ip)    PEER_HB_IP="$2"; shift 2 ;;
        --lan-ip)        LAN_IP="$2"; shift 2 ;;
        --peer-lan-ip)   PEER_LAN_IP="$2"; shift 2 ;;
        --lan-vip)       LAN_VIP="$2"; shift 2 ;;
        --authorize-key) AUTH_KEYS+=("$2"); shift 2 ;;
        --no-restart)    RESTART=0; shift ;;
        -h|--help)       usage; exit 0 ;;
        *) echo "ha-node-setup: unknown option: $1" >&2; usage >&2; exit 1 ;;
    esac
done

case "$NODE" in
    1)
        : "${HB_IP:=10.0.0.1}"       "${PEER_HB_IP:=10.0.0.2}"
        : "${LAN_IP:=192.168.1.2}"   "${PEER_LAN_IP:=192.168.1.3}"
        PRIORITY=150
        ;;
    2)
        : "${HB_IP:=10.0.0.2}"       "${PEER_HB_IP:=10.0.0.1}"
        : "${LAN_IP:=192.168.1.3}"   "${PEER_LAN_IP:=192.168.1.2}"
        PRIORITY=100
        ;;
    *) echo "ha-node-setup: --node must be 1 or 2" >&2; exit 1 ;;
esac

if [ "$(id -u)" != 0 ]; then
    echo "ha-node-setup: must run as root" >&2
    exit 1
fi

echo "==> Writing /etc/ha-router/node.env"
mkdir -p /etc/ha-router
cat > /etc/ha-router/node.env <<EOF
# Generated by ha-node-setup. Machine-local; not part of the bootc image.
NODE_ID=$NODE
PRIORITY=$PRIORITY
HB_IP=$HB_IP
PEER_HB_IP=$PEER_HB_IP
LAN_IP=$LAN_IP
PEER_LAN_IP=$PEER_LAN_IP
LAN_VIP=$LAN_VIP
WAN_MAC=$WAN_MAC
EOF
chmod 644 /etc/ha-router/node.env

echo "==> Rendering keepalived and conntrackd configuration"
# Rendering lives in ha-router-render, which also runs at every boot (via
# ha-router-render.service) so image updates that change the templates can
# never leave stale rendered configs behind in the machine-local /etc.
/usr/bin/ha-router-render

nm_profile() { # name interface address
    local file="/etc/NetworkManager/system-connections/$1.nmconnection"
    cat > "$file" <<EOF
[connection]
id=$1
type=ethernet
interface-name=$2
autoconnect=true

[ipv4]
method=manual
address1=$3

[ipv6]
method=disabled
EOF
    chmod 600 "$file"
}

echo "==> Writing NetworkManager profiles (heartbeat + LAN)"
nm_profile ha-heartbeat enu1u1 "${HB_IP}/30"
nm_profile ha-lan enu1u2 "${LAN_IP}/24"

echo "==> Setting up ssh trust for lease sync"
# On bootc/ostree systems /root is a symlink to /var/roothome; resolve it so
# mkdir -p works even before first boot.
ROOT_SSH="$(realpath -m /root)/.ssh"
mkdir -p "$ROOT_SSH"
chmod 700 "$ROOT_SSH"
if [ ! -f "$ROOT_SSH/id_ed25519" ]; then
    ssh-keygen -q -t ed25519 -N "" -f "$ROOT_SSH/id_ed25519" \
        -C "ha-router-node${NODE}"
fi
touch "$ROOT_SSH/authorized_keys"
chmod 600 "$ROOT_SSH/authorized_keys"
for key in "${AUTH_KEYS[@]:-}"; do
    [ -n "$key" ] || continue
    if ! grep -qxF "$key" "$ROOT_SSH/authorized_keys"; then
        echo "$key" >> "$ROOT_SSH/authorized_keys"
        echo "    authorized peer key: ${key##* }"
    fi
done

if [ "$RESTART" = 1 ]; then
    echo "==> Reloading NetworkManager and (re)starting services"
    nmcli connection reload 2>/dev/null || true
    nmcli connection up ha-heartbeat 2>/dev/null || true
    nmcli connection up ha-lan 2>/dev/null || true
    systemctl enable --now nftables.service conntrackd.service \
        keepalived.service
    systemctl restart conntrackd.service keepalived.service
fi

cat <<EOF

Node $NODE configured (priority $PRIORITY, heartbeat $HB_IP, LAN $LAN_IP,
VIP $LAN_VIP, shared WAN MAC $WAN_MAC).

This node's public key (authorize it on the peer so lease sync works):

  $(cat "$ROOT_SSH/id_ed25519.pub")

On the peer, run:
  ha-node-setup --node $((3 - NODE)) --authorize-key '$(cat "$ROOT_SSH/id_ed25519.pub")'
EOF
